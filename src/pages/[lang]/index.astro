---
import { getCollection } from "astro:content";
import Layout from "../../components/Layout.astro";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import Search from "../../components/Search.astro";
import { allRegions, regionMap, langMatcher, getCatsConfig, catLabel as _catLabel, subLabel as _subLabel, buildDdObj, buildSearchPosts } from "../../lib/utils";

export function getStaticPaths() {
  return allRegions.map(r => ({ params: { lang: r } }));
}

const { lang } = Astro.params;
const langCode = regionMap[lang] || "zh";
const matchLang = langMatcher(langCode);

const allPosts = await getCollection("posts", ({ data }) => !data.draft && matchLang(data.lang));
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = posts.filter(p => p.data.featured).slice(0, 3);
const catsConfig = await getCatsConfig();
const categories = Object.keys(catsConfig);
const catLabel = (key: string) => _catLabel(key, langCode, catsConfig);
const subLabel = (catKey: string, subKey: string) => _subLabel(catKey, subKey, langCode, catsConfig);
const byCategory = (cat: string) => posts.filter(p => p.data.category === cat);

const ddObj = buildDdObj(categories, catsConfig, langCode, lang, byCategory);
const searchPosts = buildSearchPosts(posts, lang, catsConfig, langCode);

const featLabel: Record<string, string> = {
  zh: "精选", "zh-tw": "精選", "zh-yue": "精選",
  en: "Featured", ja: "おすすめ", ko: "추천",
  fr: "Sélection", de: "Empfohlen", es: "Destacado",
};

// Build hero + mini-grid server-side (no more client JS timing issues)
const heroPosts = posts.filter(p => p.data.featured);
const heroByCat: Record<string, typeof heroPosts> = {};
heroPosts.forEach(p => { if (!heroByCat[p.data.category]) heroByCat[p.data.category] = []; heroByCat[p.data.category].push(p); });
const heroCats = Object.keys(heroByCat).sort(() => Math.random() - 0.5);
const heroPicks: typeof heroPosts = [];
for (let i = 0; i < Math.min(9, heroCats.length); i++) {
  heroPicks.push(heroByCat[heroCats[i]][Math.floor(Math.random() * heroByCat[heroCats[i]].length)]);
}
heroPicks.sort(() => Math.random() - 0.5);
const heroTop = heroPicks.slice(0, 3);
const heroGrid = heroPicks.slice(3, 9);

const viewAllLabel: Record<string, string> = {
  zh: "查看全部 →", "zh-tw": "查看全部 →", "zh-yue": "查看全部 →",
  en: "View all →", ja: "すべて見る →", ko: "전체 보기 →",
  fr: "Tout voir →", de: "Alle anzeigen →", es: "Ver todo →",
};
const readLabel: Record<string, string> = {
  zh: "阅读文章 →", "zh-tw": "閱讀文章 →", "zh-yue": "閱讀文章 →",
  en: "Read the article →", ja: "記事を読む →", ko: "글 읽기 →",
};
---

<Layout title="NickAlphaWhite" description="NickAlphaWhite's Blog">
  <Nav {lang} {categories} {catLabel} {ddObj} />

  <Search searchPosts={searchPosts} />

  <!-- HERO + GRID — server-rendered, no client JS needed -->
  {heroTop.length > 0 && (
    <section class="hero-section">
      {heroTop.map((p, i) => (
        <a href={`/${lang}/${p.id.replace(lang + "/", "").replace(/\.md$/, "")}`} class="hero-card"
           onclick={`event.preventDefault();var el=this;var r=el.getBoundingClientRect();el.style.top=r.top+'px';el.style.left=r.left+'px';el.style.width=r.width+'px';el.style.height=r.height+'px';el.style.position='fixed';el.style.margin='0';requestAnimationFrame(function(){requestAnimationFrame(function(){el.classList.add('zooming')})});setTimeout(function(){location.href=el.href},700)`}>
          {p.data.image && <img src={p.data.image} alt={p.data.title} loading={i===0?'eager':'lazy'} />}
          <div class="hero-mask"></div>
          <div class="hero-content">
            <p class="hero-tag">{catLabel(p.data.category)}{p.data.featured ? ' · '+featLabel[langCode] || featLabel.en : ''}</p>
            <h1 class="hero-title">{p.data.title}</h1>
            {p.data.subtitle && <p class="hero-sub">{p.data.subtitle}</p>}
            <span class="hero-cta">{readLabel[langCode] || readLabel.en}</span>
          </div>
        </a>
      ))}
    </section>
  )}
  {heroGrid.length > 0 && (
    <section class="mini-grid">
      <div class="mini-grid-inner">
        {heroGrid.map(p => (
          <a href={`/${lang}/${p.id.replace(lang + "/", "").replace(/\.md$/, "")}`} class="mini-card">
            {p.data.image && <img src={p.data.image} alt={p.data.title} loading="lazy" />}
            <div class="mini-card-content">
              <p class="mini-card-tag">{catLabel(p.data.category)}</p>
              <h3 class="mini-card-title">{p.data.title}</h3>
            </div>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- SINGLE FILMSTRIP — 9 random posts from all categories -->
  {(() => {
    const filmPosts = posts.filter(p => p.data.featured);
    if (filmPosts.length === 0) return null;
    // Shuffle and pick up to 9, force odd
    const shuffled = [...filmPosts].sort(() => Math.random() - 0.5);
    let picks = shuffled.slice(0, 9);
    while (picks.length > 3 && picks.length % 2 === 0) picks = picks.slice(0, -1);
    const medianIdx = Math.floor(picks.length / 2);
    const filmId = 'film-all';
    const filmPad = picks.length < 4 ? '0' : '15%';
    return (
      <section class="film-strip" style="position:relative">
        <div class="film-outer" id={filmId}>
          <div class="film-row" style={`padding:0 ${filmPad}`}>
            {picks.map(p => (
              <a href={`/${lang}/${p.id.replace(lang + "/", "").replace(/\.md$/, "")}`} class="film-card">
                {p.data.image && <img src={p.data.image} alt={p.data.title} loading="lazy" />}
                <div class="film-content">
                  <span class="film-cat-tag">{catLabel(p.data.category)}</span>
                  <h2 class="film-title">{p.data.title}</h2>
                  {p.data.subtitle && <p class="film-sub">{p.data.subtitle}</p>}
                </div>
              </a>
            ))}
          </div>
        </div>
        <button class="film-arrow arr-left" id="film-all-l" onclick="filmScroll('film-all',-1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg></button>
        <button class="film-arrow arr-right" id="film-all-r" onclick="filmScroll('film-all',1)"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg></button>
        <div id="__filmData" style="display:none" data-median={medianIdx}></div>
      </section>
    );
  })()}

  <Footer />
</Layout>
