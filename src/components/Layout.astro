---
import { ViewTransitions } from "astro:transitions";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  htmlLang?: string;
}

const { title, description, htmlLang = "zh-CN" } = Astro.props;
---

<!doctype html>
<html lang={htmlLang} data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description || title} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <ViewTransitions />
    <title>{title}</title>

    <script is:inline>
      (function () {
        var stored = localStorage.getItem("theme");
        var theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <script>
      function applyTheme() {
        var stored = localStorage.getItem("theme");
        var theme = stored || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.style.colorScheme = theme;
        var ll=document.getElementById("logoLight"),ld=document.getElementById("logoDark");
        if(ll)ll.style.display=theme==="dark"?"none":"";
        if(ld)ld.style.display=theme==="dark"?"":"none";
      }
      document.addEventListener('astro:after-swap', applyTheme);
    </script>

    <!-- Waline — preload on every page so SPA nav works immediately -->
    <link rel="stylesheet" href="https://unpkg.com/@waline/client@v2/dist/waline.css" />
    <script src="https://unpkg.com/@waline/client@v2/dist/waline.js"></script>

    <script>
      // Waline — dynamically load and mount with language detection
      (function () {
        var walineInstance = null;

        // Map site lang codes to Waline locale codes
        var walineLocale = {
          zh: 'zh-CN', 'zh-tw': 'zh-TW', 'zh-yue': 'zh-TW',
          en: 'en-US', ja: 'ja', ko: 'ko', fr: 'fr', de: 'de',
          es: 'es', it: 'it', pt: 'pt', nl: 'nl', ru: 'ru', th: 'th'
        };
        var walinePlaceholder = {
          'zh-CN': '留下你的评论...', 'zh-TW': '留下你的評論...',
          'en-US': 'Leave your comment here...', ja: 'コメントをどうぞ...',
          ko: '댓글을 남겨주세요...', fr: 'Laissez votre commentaire...',
          de: 'Hinterlassen Sie Ihren Kommentar...', es: 'Deja tu comentario...',
          it: 'Lascia il tuo commento...', pt: 'Deixe seu comentário...',
          nl: 'Laat je reactie achter...', ru: 'Оставьте комментарий...', th: 'แสดงความคิดเห็น...'
        };

        function getWalineLang() {
          // Try localStorage first, then URL path, fallback to en
          var stored = localStorage.getItem('lang');
          if (stored && walineLocale[stored]) return walineLocale[stored];
          var regionToLang = {cn:'zh',us:'en',jp:'ja',kr:'ko',tw:'zh-tw',hk:'zh-yue',mo:'zh-yue',uk:'en',fr:'fr',de:'de',es:'es',it:'it',pt:'pt',th:'th',ca:'en','ca-fr':'fr',au:'en',nl:'nl',ru:'ru',br:'pt',mx:'es','in':'en',ae:'en',za:'en',pr:'es'};
          var m = location.pathname.match(/^\/([\w-]+)/);
          var lang = m ? (regionToLang[m[1]] || 'en') : 'en';
          return walineLocale[lang] || 'en-US';
        }

        function mountWaline() {
          var el = document.getElementById('waline');
          if (!el) return;

          // Destroy previous instance before re-init (SPA navigation)
          if (walineInstance && typeof walineInstance.destroy === 'function') {
            try { walineInstance.destroy(); } catch(e) {}
            walineInstance = null;
          }
          el.innerHTML = '';

          var wLang = getWalineLang();

          if (typeof Waline === 'undefined') return; // Still loading, retry

          walineInstance = Waline.init({
            el: el,
            serverURL: 'https://cm.nickalphawhite.top',
            appId: 'YoYVf6jrZj9qbOHH7HIk5eAp-MdYXbMMI',
            appKey: 'pQl3039kbz0eoqckIDgdSV0z',
            lang: wLang,
            avatar: 'monsterid',
            recordIP: false,
            requiredFields: ['nick'],
            visitor: true,
            dark: 'html[data-theme="dark"]',
            placeholder: walinePlaceholder[wLang] || 'Leave your comment here...'
          });
        }

        // Retry until both #waline and Waline are ready (SPA nav + script load)
        var walineRetries = 0;
        function tryMount() {
          if (document.getElementById('waline') && typeof Waline !== 'undefined') { mountWaline(); return; }
          if (++walineRetries < 20) setTimeout(tryMount, 200);
        }
        tryMount();
        document.addEventListener('astro:after-swap', function () {
          walineRetries = 0;
          tryMount();
        });
      })();
    </script>

    <script src="https://cdn.jsdelivr.net/npm/fuse.js@7.0.0/dist/fuse.min.js"></script>
  </head>
  <body>
    <slot />

    <!-- Back to top -->
    <button class="btt" id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 15 12 9 6 15"/></svg>
    </button>

    <script>
      // BTT — moves up near footer to avoid covering region label
      var btt = document.getElementById("btt");
      window.addEventListener("scroll", function () {
        if (!btt) return;
        btt.classList.toggle("visible", window.scrollY > 500);
        var distToBottom = document.documentElement.scrollHeight - window.scrollY - window.innerHeight;
        btt.style.bottom = distToBottom < 64 ? (64 - distToBottom + 24) + "px" : "24px";
      });

      // Theme toggle
      window.toggleTheme = function () {
        var c = document.documentElement.getAttribute("data-theme"),
          n = c === "dark" ? "light" : "dark";
        document.documentElement.setAttribute("data-theme", n);
        localStorage.setItem("theme", n);
        var ll=document.getElementById("logoLight"),ld=document.getElementById("logoDark");
        if(ll)ll.style.display=n==="dark"?"none":"";
        if(ld)ld.style.display=n==="dark"?"":"none";
      };

      // Init logo visibility on load
      (function(){
        var t=document.documentElement.getAttribute("data-theme");
        var ll=document.getElementById("logoLight"),ld=document.getElementById("logoDark");
        if(ll)ll.style.display=t==="dark"?"none":"";
        if(ld)ld.style.display=t==="dark"?"":"none";
      })();

      // Language — region-based display names
      var regionNames={cn:'中国大陆',us:'United States',jp:'日本',kr:'대한민국',tw:'台灣',hk:'香港',mo:'澳門',uk:'United Kingdom',fr:'France',de:'Deutschland',es:'España',it:'Italia',pt:'Portugal',th:'ประเทศไทย',ca:'Canada (English)','ca-fr':'Canada (Français)',au:'Australia',nl:'Nederland',ru:'Россия',br:'Brasil',mx:'México',in:'India',ae:'الإمارات العربية المتحدة',za:'South Africa',pr:'Puerto Rico',sg:'Singapore (English)','sg-zh':'新加坡（简体中文）'};
      var langByRegion={cn:'zh',us:'en',jp:'ja',kr:'ko',tw:'zh-tw',hk:'zh-yue',mo:'zh-yue',uk:'en',fr:'fr',de:'de',es:'es',it:'it',pt:'pt',th:'th',ca:'en','ca-fr':'fr',au:'en',nl:'nl',ru:'ru',br:'pt',mx:'es',in:'en',ae:'en',za:'en',pr:'es',sg:'en','sg-zh':'zh'};

      window.switchLang = function (lang, region) {
        var r = region || localStorage.getItem('region') || 'cn';
        var l = lang || langByRegion[r] || 'zh';
        var rl=document.getElementById('regionLabel');
        if(rl)rl.textContent=regionNames[r]||r;
        document.documentElement.setAttribute('lang', l);
        localStorage.setItem('lang', l);
        localStorage.setItem('region', r);
      };

      document.addEventListener('click',function(e){var d=document.getElementById('langDrop');if(d&&!e.target.closest('.lang-sw'))d.classList.remove('open')});
      (function () {
    var defaultLang = (document.documentElement.lang || "zh-CN").startsWith("en") ? "en" : "zh";
    var urlRegion=(location.pathname.match(/^\/([\w-]+)/)||[])[1]||"";
    var defaultRegion=langByRegion[urlRegion]?urlRegion:(defaultLang==="en"?"us":"cn");
    switchLang(localStorage.getItem("lang")||langByRegion[urlRegion]||defaultLang, localStorage.getItem("region")||defaultRegion);
  })();

      // ====================================
      // Card Scroll — overflow-driven, 1 card per click
      // ====================================

      function getStep(row) {
        var card = row.querySelector(".card");
        if (!card) return 300;
        var style = getComputedStyle(row);
        var gap = parseFloat(style.gap || 16);
        return card.offsetWidth + gap;
      }

      window.scrollRow = function (id, dir) {
        var row = document.getElementById(id);
        if (!row) return;
        var outer = row.closest(".scroll-outer");
        if (!outer) return;
        outer.scrollBy({ left: getStep(row) * dir, behavior: "smooth" });
      };

      function updateScroller(outer) {
        var row = outer.querySelector(".scroll-row");
        if (!row) return;
        var left = outer.parentElement.querySelector(".arr-left");
        var right = outer.parentElement.querySelector(".arr-right");
        if (!left || !right) return;

        var need = row.scrollWidth > outer.clientWidth + 2;
        if (!need) {
          left.classList.remove("visible");
          right.classList.remove("visible");
          return;
        }
        var max = outer.scrollWidth - outer.clientWidth;
        left.classList.toggle("visible", outer.scrollLeft > 4);
        right.classList.toggle("visible", outer.scrollLeft < max - 4);
      }

      function checkArrows() {
        document.querySelectorAll(".scroll-outer").forEach(updateScroller);
      }

      window.addEventListener("load", checkArrows);
      window.addEventListener("resize", checkArrows);
      document.querySelectorAll(".scroll-outer").forEach(function (o) {
        o.addEventListener("scroll", checkArrows);
      });

      // Filmstrip peek-a-boo scroll
      window.filmScroll = function (filmId, dir) {
        var outer = document.getElementById(filmId);
        if (!outer) return;
        var w = (outer.querySelector(".film-card")?.offsetWidth || 500) + 2; // card + gap
        outer.scrollBy({ left: dir * w, behavior: "smooth" });
        setTimeout(checkFilmArrows, 400);
      };
      function checkFilmArrows() {
        document.querySelectorAll(".film-outer").forEach(function (outer) {
          var strip = outer.closest(".film-strip");
          if (!strip) return;
          var left = strip.querySelector(".arr-left");
          var right = strip.querySelector(".arr-right");
          if (!left || !right) return;
          var ovf = outer.scrollWidth > outer.clientWidth + 4;
          if (!ovf) { left.classList.remove("visible"); right.classList.remove("visible"); return; }
          left.classList.toggle("visible", outer.scrollLeft > 4);
          right.classList.toggle("visible", outer.scrollLeft + outer.clientWidth < outer.scrollWidth - 4);
        });
      }

      // Scroll filmstrip to median on load + after view transitions
      function resetAndCenterFilm(scrollToTop) {
        var outer = document.getElementById('film-all');
        if (!outer) return;
        if (scrollToTop) window.scrollTo(0, 0);
        var filmData = document.getElementById('__filmData');
        if (!filmData || !filmData.dataset.median) return;
        var medianIdx = parseInt(filmData.dataset.median);
        if (medianIdx <= 0) return;
        // Center on the median card without a visible reset-to-zero flash
        requestAnimationFrame(function(){
          requestAnimationFrame(function(){
            var cards = outer.querySelectorAll('.film-card');
            if (!cards[medianIdx]) return;
            var t = cards[medianIdx];
            var ow = outer.getBoundingClientRect().width;
            outer.scrollTo({ left: Math.max(0, t.offsetLeft - (ow - t.offsetWidth) / 2), behavior: "instant" });
            setTimeout(function(){ checkFilmArrows(); }, 200);
          });
        });
      }
      window.addEventListener('load', function(){ setTimeout(function(){ resetAndCenterFilm(true); }, 500); });
      document.addEventListener('astro:after-swap', function(){
        window.scrollTo(0, 0);
        setTimeout(function(){ resetAndCenterFilm(false); }, 300);
      });
      // Re-center filmstrip on resize WITHOUT scrolling to top (mobile address bar hide/show triggers resize)
      var _rcTimer;
      window.addEventListener('resize', function(){
        clearTimeout(_rcTimer);
        _rcTimer = setTimeout(function(){ resetAndCenterFilm(false); }, 300);
      });

      window.addEventListener("load", function () {
        setTimeout(checkFilmArrows, 200); setTimeout(checkFilmArrows, 800);
      });
      document.querySelectorAll(".film-outer").forEach(function (r) { r.addEventListener("scroll", checkFilmArrows); });

      // Re-init arrows after ViewTransitions
      document.addEventListener('astro:after-swap', function () {
        setTimeout(checkArrows, 200); setTimeout(checkArrows, 600);
        setTimeout(checkFilmArrows, 200); setTimeout(checkFilmArrows, 600);
        document.querySelectorAll(".scroll-outer").forEach(function (r) { r.addEventListener("scroll", checkArrows); });
        document.querySelectorAll(".film-outer").forEach(function (r) { r.addEventListener("scroll", checkFilmArrows); });
      });

      // Nav dropdown — uses delegation so it survives view transitions
      (function () {
        var open = false, timer = null, animating = false, animTimer = null, currentCat = null;
        // Re-query DOM refs each time (survives view transitions)
        function dd(){return document.getElementById("navDropdown")}
        function mega(){return document.getElementById("megaInner")}
        function backdrop(){return document.getElementById("navBackdrop")}
        function navBar(){return document.querySelector(".nav")}

        function getData(){return window.__DD||{}}
        var ddText = {
          zh:{explore:'探索 ',all:'全部 ',recent:'最近更新',more:'更多',allArticles:'全部文章',popular:'热门',subscribe:'订阅',soon:'即将上线'},
          'zh-tw':{explore:'探索 ',all:'所有 ',recent:'最近更新',more:'更多',allArticles:'所有文章',popular:'熱門',subscribe:'訂閱',soon:'即將上線'},
          'zh-yue':{explore:'發掘 ',all:'全部 ',recent:'最新更新',more:'更多',allArticles:'全部文章',popular:'熱門',subscribe:'訂閱',soon:'快將推出'},
          en:{explore:'Explore ',all:'All ',recent:'Recent',more:'More from ',allArticles:'All articles',popular:'Most popular',subscribe:'Subscribe',soon:'Coming soon'},
          ja:{explore:' ',all:'すべての ',recent:'最近',more:'もっと見る ',allArticles:'すべての記事',popular:'人気',subscribe:'購読',soon:'近日公開'},
          ko:{explore:' ',all:'모든 ',recent:'최근',more:'더 보기 ',allArticles:'모든 글',popular:'인기',subscribe:'구독',soon:'곧 공개'},
          fr:{explore:'Explorer ',all:'Tout ',recent:'Récent',more:'Plus de ',allArticles:'Tous les articles',popular:'Populaire',subscribe:'Sabonner',soon:'Prochainement'},
          de:{explore:'Entdecken ',all:'Alle ',recent:'Neueste',more:'Mehr von ',allArticles:'Alle Artikel',popular:'Beliebt',subscribe:'Abonnieren',soon:'Demnächst'},
          es:{explore:'Explorar ',all:'Todo ',recent:'Reciente',more:'Más de ',allArticles:'Todos los artículos',popular:'Popular',subscribe:'Suscribir',soon:'Próximamente'},
          it:{explore:'Esplora ',all:'Tutto ',recent:'Recente',more:'Altro da ',allArticles:'Tutti gli articoli',popular:'Popolare',subscribe:'Iscriviti',soon:'Prossimamente'},
          pt:{explore:'Explorar ',all:'Tudo ',recent:'Recente',more:'Mais de ',allArticles:'Todos os artigos',popular:'Popular',subscribe:'Assinar',soon:'Em breve'},
          nl:{explore:'Ontdek ',all:'Alles ',recent:'Recent',more:'Meer van ',allArticles:'Alle artikelen',popular:'Populair',subscribe:'Abonneren',soon:'Binnenkort'},
          ru:{explore:' ',all:'Всё ',recent:'Недавнее',more:'Ещё ',allArticles:'Все статьи',popular:'Популярное',subscribe:'Подписка',soon:'Скоро'},
          th:{explore:'สำรวจ ',all:'ทั้งหมด ',recent:'ล่าสุด',more:'เพิ่มเติม ',allArticles:'บทความทั้งหมด',popular:'ยอดนิยม',subscribe:'ติดตาม',soon:'เร็วๆ นี้'}
        };
        function t(key) {
          // Detect language from URL path first (most reliable)
          var regionToLang={cn:'zh',us:'en',jp:'ja',kr:'ko',tw:'zh-tw',hk:'zh-yue',mo:'zh-yue',uk:'en',fr:'fr',de:'de',es:'es',it:'it',pt:'pt',th:'th',ca:'en','ca-fr':'fr',au:'en',nl:'nl',ru:'ru',br:'pt',mx:'es','in':'en',ae:'en',za:'en',pr:'es',sg:'en','sg-zh':'zh'};
          var m=location.pathname.match(/^\/(\w[\w-]*)/);
          var lang=regionToLang[m?m[1]:'']||localStorage.getItem('lang')||'zh';
          // Normalize zh-tw / zh-yue (split('-')[0] would break them)
          var map=ddText[lang]||ddText.zh;
          return map[key]||key;
        }
        function show(cat) {
          var dd_data = getData();
          if (!dd_data[cat]) return;
          var d = dd_data[cat];
          var subs = d.subcategories || [];
          var h = '';
          h += '<div class="mega-col bold"><p class="mega-label">' + t('explore') + d.label + '</p>';
          h += '<a href="' + d.all + '">' + t('all') + d.label + '</a>';
          subs.forEach(function (s) { h += '<a href="' + s.url + '">' + s.name + '</a>'; });
          h += '</div>';
          h += '<div class="mega-col"><p class="mega-label">' + t('recent') + '</p>';
          if (d.posts && d.posts.length) {
            d.posts.slice(0, 4).forEach(function (p) { h += '<a href="' + p.url + '">' + p.title + '</a>'; });
          } else {
            h += '<a href="' + d.all + '">' + t('soon') + '</a>';
          }
          h += '</div>';
          h += '<div class="mega-col"><p class="mega-label">' + t('more') + d.label + '</p>';
          h += '<a href="' + d.all + '">' + t('allArticles') + '</a>';
          h += '<a href="' + d.all + '">' + t('popular') + '</a>';
          h += '<a href="' + d.all + '">' + t('subscribe') + '</a>';
          h += '</div>';

          var ddEl=dd(), m=mega(), b=backdrop(), n=navBar();
          if (open && m.innerHTML !== h) {
            // Fast switch in progress → just snap to new content
            if (animating) {
              if (animTimer) { clearTimeout(animTimer); animTimer = null; }
              animating = false;
              m.style.opacity = ''; ddEl.style.height = '';
              m.innerHTML = h;
            } else {
              animating = true;
              ddEl.style.height = ddEl.offsetHeight + 'px';
              m.style.opacity = '0';
              animTimer = setTimeout(function () {
                m.innerHTML = h;
                requestAnimationFrame(function () {
                  m.style.opacity = '1';
                  var newH = m.scrollHeight + 88;
                  ddEl.style.height = newH + 'px';
                  animTimer = setTimeout(function () { animating = false; animTimer = null; }, 650);
                });
              }, 60);
            }
          } else if (!open) {
            m.innerHTML = h;
          }
          ddEl.classList.add("open");
          if(b) b.classList.add("active");
          if(n) n.classList.add("solid");
          open = true;
        }

        function hide() {
          var ddEl=dd(), b=backdrop(), n=navBar();
          if(ddEl) ddEl.classList.remove("open");
          if(b) b.classList.remove("active");
          if(n) n.classList.remove("solid");
          open = false;
          animating = false;
          if (animTimer) { clearTimeout(animTimer); animTimer = null; }
          if(ddEl) { ddEl.style.height = ''; ddEl.style.opacity = ''; }
          var m = mega(); if(m) m.style.opacity = '';
        }

        function cancelHide() { if (timer) { clearTimeout(timer); timer = null; } }

        function scheduleHide() {
          cancelHide();
          timer = setTimeout(function () { hide(); currentCat = null; }, 300);
        }

        // Helper: is the target inside the nav bar or dropdown?
        function isInNavOrDD(target) {
          return target && target.closest && (target.closest(".nav-link") || target.closest("#navDropdown") || target.closest(".nav"));
        }

        // Hover on nav-link → show dropdown
        document.addEventListener("mouseover", function (e) {
          var link = e.target.closest && e.target.closest(".nav-link");
          if (!link) return;
          cancelHide();
          var cat = link.getAttribute("data-cat");
          if (cat && cat !== currentCat) { currentCat = cat; show(cat); }
        });

        // Hover into dropdown → keep it open
        document.addEventListener("mouseover", function (e) {
          if (e.target.closest && e.target.closest("#navDropdown")) cancelHide();
        });

        // Leave nav-link OR leave dropdown → schedule hide (unless moving within nav/dropdown)
        document.addEventListener("mouseout", function (e) {
          if (e.target.closest && e.target.closest(".nav-link")) {
            if (isInNavOrDD(e.relatedTarget)) return;
            scheduleHide();
            return;
          }
          if (e.target.closest && e.target.closest("#navDropdown")) {
            if (isInNavOrDD(e.relatedTarget)) return;
            scheduleHide();
          }
        });
      })();

      // Search
      (function () {
        var fuse, searchPosts = [], idx = -1, timer;
        var overlay = document.getElementById("searchOverlay"),
            input = document.getElementById("searchInput"),
            results = document.getElementById("searchResults");

        function build() {
          searchPosts = [];
          // Index from data attribute (all posts) if available, fallback to DOM
          var el = document.getElementById('__searchData');
          if (el && el.dataset.posts) {
            try { searchPosts = JSON.parse(el.dataset.posts); } catch(e) {}
          }
          if (!searchPosts.length) {
            document.querySelectorAll(".hero-card, .card").forEach(function (c) {
              var t = c.querySelector(".hero-title, .card-title"),
                  d = c.querySelector(".hero-sub, .card-desc"),
                  g = c.querySelector(".hero-tag, .card-tag"),
                  u = (c.closest("a") || c).getAttribute("href") || "#";
              if (t) searchPosts.push({
                title: t.textContent.replace(/\s+/g, " ").trim(),
                excerpt: d ? d.textContent.trim() : "",
                category: g ? g.textContent.trim() : "",
                url: u,
              });
            });
          }
          if (searchPosts.length && typeof Fuse !== "undefined")
            fuse = new Fuse(searchPosts, {
              keys: [{ name: "title", weight: 0.5 }, { name: "excerpt", weight: 0.3 }, { name: "category", weight: 0.2 }],
              threshold: 0.4, distance: 100, includeMatches: true, minMatchCharLength: 1,
            });
        }

        function search(q) {
          if (!results) return;
          q = q.trim();
          var lang = localStorage.getItem("lang") || "zh";
          if (!q || !fuse) { results.innerHTML = '<div class="search-empty">' + (lang === "zh" ? "输入关键词搜索" : "Start typing") + '</div>'; idx = -1; return; }
          var f = fuse.search(q);
          if (!f.length) { results.innerHTML = '<div class="search-empty">' + (lang === "zh" ? "没有找到 &ldquo;" : "No results for &ldquo;") + esc(q) + '&rdquo;</div>'; idx = -1; return; }
          var h = "", lim = Math.min(f.length, 10);
          for (var i = 0; i < lim; i++) {
            var it = f[i].item;
            h += '<a class="search-result' + (i === idx ? " active" : "") + '" href="' + it.url + '"><span class="search-result-name">' + esc(it.title) + '</span>';
            if (it.excerpt) h += '<span class="search-result-desc">' + esc(it.excerpt.substring(0, 130)) + '</span>';
            if (it.category) h += '<span class="search-result-tag">' + esc(it.category) + '</span>';
            h += '</a>';
          }
          results.innerHTML = h;
        }

        function esc(s) { var d = document.createElement("div"); d.appendChild(document.createTextNode(s)); return d.innerHTML; }

        function nav(e) {
          var items = results.querySelectorAll(".search-result");
          if (!items.length) return;
          if (e.key === "ArrowDown") { e.preventDefault(); idx = Math.min(idx + 1, items.length - 1); }
          else if (e.key === "ArrowUp") { e.preventDefault(); idx = Math.max(idx - 1, 0); }
          else if (e.key === "Enter") { e.preventDefault(); if (idx >= 0 && items[idx]) window.location.href = items[idx].href; return; }
          else return;
          items.forEach(function (it, i) { it.classList.toggle("active", i === idx); if (i === idx) it.scrollIntoView({ block: "nearest" }); });
        }

        window.openSearch = function () {
          if (!overlay) return;
          overlay.classList.add("active"); input.value = "";
          var lang = localStorage.getItem("lang") || "zh";
          input.placeholder = lang === "zh" ? "搜索文章…" : "Search…";
          results.innerHTML = '<div class="search-empty">' + (lang === "zh" ? "输入关键词搜索" : "Start typing") + '</div>';
          idx = -1; setTimeout(function () { input.focus(); }, 150);
          document.body.style.overflow = "hidden";
        };
        window.closeSearch = function () {
          if (!overlay) return;
          overlay.classList.remove("active"); document.body.style.overflow = ""; idx = -1;
        };

        document.addEventListener("keydown", function (e) {
          if (!overlay) return;
          var isInp = document.activeElement && /INPUT|TEXTAREA/.test(document.activeElement.tagName);
          if (((e.ctrlKey || e.metaKey) && e.key === "k") || (e.key === "/" && !isInp)) { e.preventDefault(); window.openSearch(); }
          if (e.key === "Escape" && overlay.classList.contains("active")) window.closeSearch();
        });

        input.addEventListener("input", function () { clearTimeout(timer); idx = -1; timer = setTimeout(function () { search(input.value); }, 200); });
        input.addEventListener("keydown", function (e) { if (["ArrowDown", "ArrowUp", "Enter"].includes(e.key)) nav(e); });
        overlay.addEventListener("click", function (e) { if (e.target === overlay) window.closeSearch(); });

        window.addEventListener("load", function () { setTimeout(build, 300); });
      })();
    </script>
  </body>
</html>
