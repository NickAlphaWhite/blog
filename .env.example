# GitHub Personal Access Token (classic) with "repo" scope
# Used for fast GitHub API pushes (< 1s instead of git push)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Git identity (for commit author)
GIT_USER=NickAlphaWhite
GIT_EMAIL=nick@nickalphawhite.top

# Port for the admin server (default: 3456)
PORT=3456

# Admin token — used for login and API authentication
# Generate a strong random value: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-to-a-strong-random-string

# Disable git push in dev mode (set to "false" to skip all pushes)
GIT_PUSH_ENABLED=true

# Production site URL
SITE_URL=https://blog.nickalphawhite.top
